[project]
requires = ["nodejs-24"]

[dev]
build = ["bash", "./scripts/prepare.sh"]
run = ["bash", "./scripts/dev.sh"]
deps = ["git"] # -> apt install git

[deploy]
build = ["bash","./scripts/build.sh"]
run = ["bash","./scripts/start.sh"]
deps = ["git"] # -> apt install git
env = ["ARK_API_KEY", "COZE_BUCKET_ENDPOINT_URL", "COZE_BUCKET_NAME"]
